generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id             Int      @id @default(autoincrement())
  slug           String   @unique(map: "BlogPost_slug_key")
  title          String
  summary        String   @db.VarChar(500)
  content        String   @db.Text
  image          String?
  isActive       Boolean  @default(true)
  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.VarChar(500)
  seoKeywords    String?  @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("blogpost")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  service   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contactsubmission")
}

model ServicePage {
  id              Int      @id @default(autoincrement())
  slug            String   @unique(map: "ServicePage_slug_key")
  title           String
  seoTitle        String?  @db.VarChar(255)
  seoDescription  String?  @db.VarChar(500)
  seoKeywords     String?  @db.VarChar(255)
  content         String   @db.Text
  image           String?
  category        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  contentTitle    String?  @db.VarChar(255)
  heroDescription String?  @db.VarChar(500)

  @@map("servicepage")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String   @db.VarChar(45)
  timestamp DateTime @default(now())
  success   Boolean

  @@map("loginattempt")
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.LongText
  
  @@map("sitesetting")
}
